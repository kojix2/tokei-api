# Cache database configuration
# Default is intentionally ephemeral. On platforms like Koyeb, this cache is
# discarded when the instance is replaced.
CACHE_DB_PATH=/tmp/tokei-api/tokei-api.sqlite3

# Application settings
PORT=3000
KEMAL_ENV=development
# Canonical public base URL for generated absolute links, OG tags, and badge URLs.
# Set this in production. Do not derive it from Host or X-Forwarded-* headers.
# BASE_URL=https://your-tokei-api-domain

# Temporary directory for git clones
TEMP_DIR=/tmp/tokei-api

# Cache retention
RETENTION_DAYS=7

# Git clone settings
# Timeout in seconds for git clone operations (default: 30)
# CLONE_TIMEOUT_SECONDS=60
